# ==================== DATABASE ====================
#
# Option A: Supabase cloud (recommended)
# 1. Create project at https://supabase.com/dashboard
# 2. Go to Settings > Database > Connection string (URI)
# 3. Use pooled (port 6543) for DATABASE_URL and direct (db.*.supabase.co:5432) for DIRECT_URL
#
# DATABASE_URL — pooled via PgBouncer (runtime queries, many short-lived connections)
# DIRECT_URL  — direct to DB, bypassing pooler (Prisma CLI: db push, migrate)
#
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
#
# Verify connection (from packages/server):
#   echo "SELECT 1" | pnpm exec prisma db execute --stdin --schema prisma/schema.prisma
#   pnpm db:push   (also applies schema)
#
# Option B: Local PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/dea_db?schema=public"
# DIRECT_URL is not needed for local — omit or leave empty

# ==================== AUTH (NextAuth v5) ====================
# Generate secret: openssl rand -base64 32
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ==================== GITHUB (optional) ====================
# Required only for GitHub OAuth login + repo access
# Create OAuth App: https://github.com/settings/developers
# Scopes: read:user, user:email, repo
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ==================== ADMIN ====================
# Email that gets ADMIN role on registration (case-insensitive)
ADMIN_EMAIL="admin@example.com"

# ==================== LLM PROVIDER ====================
# "ollama" (local, default) or "openrouter" (cloud)
LLM_PROVIDER="ollama"

# Ollama
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5-coder:32b"

# OpenRouter (required only if LLM_PROVIDER="openrouter")
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="qwen/qwen-2.5-coder-32b-instruct"
# Provider routing preferences (recommended defaults for stable JSON output)
# Use comma-separated slugs from OpenRouter provider list
OPENROUTER_PROVIDER_ORDER="Chutes"
OPENROUTER_PROVIDER_IGNORE="Cloudflare"
# Keep true for production reliability; set false for strict A/B reproducibility tests
OPENROUTER_ALLOW_FALLBACKS="true"
# Route only to providers that support all requested parameters (e.g. response_format)
OPENROUTER_REQUIRE_PARAMETERS="true"

# Parallel LLM requests (auto: 10 for openrouter, 1 for ollama)
# OpenRouter: $1 balance = 1 RPS, max 500. Safe default: 10
# LLM_CONCURRENCY=10

# ==================== PIPELINE MODE ====================
# "local" (default) — runs Python pipeline as subprocess on Vercel
# "modal" — triggers Modal serverless for heavy compute (production)
PIPELINE_MODE=local

# Modal endpoint URL (required when PIPELINE_MODE=modal)
# Get from: cd packages/modal && modal deploy app.py
MODAL_ENDPOINT_URL=

# Shared secret for Modal trigger authentication
# Generate: openssl rand -hex 32
MODAL_WEBHOOK_SECRET=

# Vercel Cron authentication secret
# Used by /api/cron/analysis-watchdog and service access to:
# - /api/admin/monitoring
# - /api/admin/orders/[id]/diagnostics
# Generate: openssl rand -hex 32
CRON_SECRET=

# Optional git tuning for analysis clone/fetch (local worker).
# For Modal worker set the same vars in Modal secret (devghost-worker-tuning).
# GIT_PARTIAL_CLONE=1
# GIT_FETCH_TIMEOUT_SEC=600
# GIT_CLONE_TIMEOUT_SEC=1800
# GIT_LOG_TIMEOUT_SEC=300
# GIT_SHALLOW_BUFFER_DAYS=14
# LAST_N_SHALLOW_INITIAL_DAYS=30
# LAST_N_SHALLOW_MAX_DAYS=3650
# LAST_N_SHALLOW_GROWTH_FACTOR=2

# ==================== HEALTH & MONITORING ====================
# Optional: Bearer token for /api/health/ready (UptimeRobot, Better Uptime)
# HEALTH_CHECK_SECRET=

# Sentry (client error tracking, optional)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=   # For source map uploads in CI

# ==================== RATE LIMITING (optional) ====================
# Upstash Redis for API rate limiting. Without these, rate limiting is disabled (graceful degradation).
# Get credentials at: https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ==================== BILLING ====================
# Set to 'true' to enable credit checks and Stripe integration.
# Default: false (all users can run analysis without credits).
BILLING_ENABLED=false

# ==================== STRIPE (optional, required for payments) ====================
# Get keys at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
